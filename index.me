<script>
document.addEventListener('DOMContentLoaded', () => {
  
  // --- 1. SPA ROUTER SYSTEM ---
  const navLinks = document.querySelectorAll('[data-nav]');
  const pages = document.querySelectorAll('.page');

  function navigateTo(targetPageId) {
    pages.forEach(page => page.classList.remove('active'));
    
    const activePage = document.getElementById(`page-${targetPageId}`);
    if (activePage) {
      activePage.classList.add('active');
    }

    // Update active state in nav elements
    document.querySelectorAll('.nav-links a').forEach(link => {
      if (link.getAttribute('data-nav') === targetPageId) {
        link.classList.add('active');
      } else {
        link.classList.remove('active');
      }
    });

    // Reset mobile menu on navigation
    document.querySelector('.nav-links').classList.remove('open');
    document.querySelector('.nav-toggle').classList.remove('open');

    // Scroll cleanly to header
    window.scrollTo({ top: 0, behavior: 'smooth' });
    
    // Trigger counters if turning to home
    if (targetPageId === 'home') {
      setTimeout(runCounters, 100);
    }
    
    // Trigger structural scroll animations
    handleScrollReveal();
  }

  navLinks.forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const target = link.getAttribute('data-nav');
      navigateTo(target);
    });
  });

  // --- 2. MOBILE NAVIGATION DRAWER ---
  const navToggle = document.querySelector('.nav-toggle');
  const navMenu = document.querySelector('.nav-links');

  if (navToggle && navMenu) {
    navToggle.addEventListener('click', () => {
      navToggle.classList.toggle('open');
      navMenu.classList.toggle('open');
    });
  }

  // --- 3. NUMERICAL HERO STATS COUNTER ANIMATION ---
  function runCounters() {
    const counters = document.querySelectorAll('.num');
    counters.forEach(counter => {
      const target = parseInt(counter.getAttribute('data-count'), 10);
      const suffix = counter.getAttribute('data-suffix') || '';
      if (isNaN(target)) return;
      
      let current = 0;
      const duration = 1200; 
      const increment = target / (duration / 16);

      const updateCount = () => {
        current += increment;
        if (current >= target) {
          counter.textContent = target + suffix;
        } else {
          counter.textContent = Math.floor(current) + suffix;
          requestAnimationFrame(updateCount);
        }
      };
      updateCount();
    });
  }
  runCounters();

  // --- 4. SCROLL VISIBILITY REVEAL ENGINE ---
  const revealElements = document.querySelectorAll('.reveal');
  function handleScrollReveal() {
    revealElements.forEach(el => {
      const elementTop = el.getBoundingClientRect().top;
      const windowHeight = window.innerHeight;
      if (elementTop < windowHeight * 0.88) {
        el.classList.add('is-visible');
      }
    });
  }
  window.addEventListener('scroll', handleScrollReveal);
  handleScrollReveal(); // Run once initially

  // --- 5. INTERACTIVE SIMULATION GAME ENGINE ---
  const gameData = [
    {
      title: "Scenario 1: The Border Flashpoint",
      desc: "An unrecognized intelligence drone has crashed inside a heavily demilitarized buffer zone. Two opposing nations are deploying defensive line units forward. You hold the floor as the Head Delegate. What is your first action?",
      choices: [
        { text: "Motion for an Immediate Moderated Caucus regarding 'Border Demarcation Protection Measures'.", score: 10, feedback: "Excellent protocol selection. This establishes structured debate and cool-headed dialogue under UN rules." },
        { text: "Release a rapid unilateral press statement condemning the opposing country's defensive moves.", score: 2, feedback: "Unilateral statements without consulting committee blocs escalate panic and reduce your negotiation capital." },
        { text: "Enter an unmoderated caucus instantly to draft a binding emergency resolution with close allies.", score: 7, feedback: "Strategic, but missing early consensus. Allies help, but you need the broader committee room engaged first." }
      ]
    },
    {
      title: "Scenario 2: The Working Paper Stand-off",
      desc: "Your block has successfully drafted a comprehensive treaty modification framework, but a rival coalition threatens a hard veto over Clause 4 (Tech Inspections). How do you salvage your policy?",
      choices: [
        { text: "Refuse any amendments. Force a high-stakes floor vote to expose their obstructionism publicly.", score: 4, feedback: "A dead-locked resolution yields no real progress. Real diplomacy requires structured compromise." },
        { text: "Propose a minor amendment replacing rigid inspection dates with mutually agreed oversight terms.", score: 10, feedback: "Superb diplomatic finesse. You preserved the inspection goal while adjusting terms to bypass the veto threat." },
        { text: "Withdraw the paper entirely and begin drafting a brand new compromise document from scratch.", score: 5, feedback: "This wastes precious working hours. Modifying existing working assets is far more efficient." }
      ]
    },
    {
      title: "Scenario 3: The Final Plenary Gavel",
      desc: "The voting block is commencing in 10 minutes. A swing nation delegate approaches you offering support if you endorse their minor agricultural subsidy proposal in a separate sub-clause. What do you do?",
      choices: [
        { text: "Accept immediately and update the co-sponsor ledger list before voting procedures lock.", score: 10, feedback: "Masterful horse-trading. Merging reasonable cross-interests is exactly how winning MUN coalitions pass resolutions." },
        { text: "Decline. Your draft must remain pure and single-topic focused without external clutter.", score: 6, feedback: "Purity is admirable, but bills fail without numbers. Building wide voting coalitions is key to global consensus." }
      ]
    }
  ];

  let currentGameStage = 0;
  let totalScore = 0;

  const stageTitle = document.getElementById('game-stage-title');
  const stageDesc = document.getElementById('game-stage-desc');
  const choicesContainer = document.getElementById('game-choices');
  const feedbackBox = document.getElementById('game-feedback-box');
  const feedbackText = document.getElementById('game-feedback-text');
  const nextBtn = document.getElementById('game-next-btn');

  function renderGameStage() {
    feedbackBox.style.display = 'none';
    choicesContainer.innerHTML = '';

    if (currentGameStage < gameData.length) {
      const stage = gameData[currentGameStage];
      stageTitle.textContent = stage.title;
      stageDesc.textContent = stage.desc;

      stage.choices.forEach(choice => {
        const btn = document.createElement('button');
        btn.className = 'game-opt-btn';
        btn.textContent = choice.text;
        btn.addEventListener('click', () => handleChoiceSelection(choice));
        choicesContainer.appendChild(btn);
      });
    } else {
      // Game end state
      stageTitle.textContent = "Simulation Concluded";
      let performanceEval = "Outstanding Diplomat. You are fully prepared to lead delegations at international forums.";
      if (totalScore < 20) performanceEval = "Capable Delegate. With focused training on rules of procedure, your floor leverage will grow.";
      
      stageDesc.textContent = `Thank you for processing through the TISPCMUN Crisis Simulator. Total Diplomatic Capability Score: ${totalScore} / 30. ${performanceEval}`;
      nextBtn.textContent = "Restart Simulator";
    }
  }

  function handleChoiceSelection(choice) {
    totalScore += choice.score;
    feedbackText.textContent = choice.feedback;
    feedbackBox.style.display = 'block';
    choicesContainer.innerHTML = ''; // Lock selections
  }

  nextBtn.addEventListener('click', () => {
    if (currentGameStage < gameData.length) {
      currentGameStage++;
    } else {
      currentGameStage = 0;
      totalScore = 0;
      nextBtn.textContent = "Proceed to Next Phase";
    }
    renderGameStage();
  });

  // Run game initial rendering pass
  renderGameStage();
});
</script>
